# Common baseline config for local M2 development
APP_ENV=local
HTTP_ADDR=:8080
LOG_LEVEL=info

# Control-plane upstreams used by ingress-service
IDENTITY_SERVICE_BASE_URL=http://identity-service:8080
APIKEY_SERVICE_BASE_URL=http://apikey-service:8080

# Shared infrastructure endpoints
POSTGRES_DSN=postgres://gateway:gateway@postgres:5432/llm_gateway?sslmode=disable
REDIS_ADDR=redis:6379
KAFKA_BROKERS=kafka:9092
