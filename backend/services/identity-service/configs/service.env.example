# Common baseline config for local M1/M2 development
APP_ENV=local
HTTP_ADDR=:8080
LOG_LEVEL=info

# Identity specific
IDENTITY_JWT_SECRET=dev-identity-secret

# Shared infrastructure endpoints
POSTGRES_DSN=postgres://gateway:gateway@postgres:5432/llm_gateway?sslmode=disable
REDIS_ADDR=redis:6379
KAFKA_BROKERS=kafka:9092
